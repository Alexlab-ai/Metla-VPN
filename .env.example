# ============================
# Metla VPN — Environment Variables
# Copy this file to .env and fill in the values
# ============================

# --- Telegram Bot ---
TGBOT_TOKEN=your_telegram_bot_token
HEAD_BOT_ADMIN_IDS=123456789           # comma-separated admin Telegram IDs
SERVICE_NAME=Metla VPN
BACK_BTN_TEXT=⬅️ Назад
CANCEL_BTN_TEXT=❌ Отмена
MENU_BTN_TEXT=📲 Меню
DEF_ANSWERTEXT=Ошибка

# --- PostgreSQL Database ---
DB_NAME=metlavpn
DB_USER=metlavpn
DB_PASS=your_db_password
DB_HOST=localhost
DB_PORT=5432

# --- Marzban (VLESS Server) ---
# URL of your Marzban panel on a separate VPS (with trailing slash!)
MARZBAN_WEB_ADMIN=https://your-vps-ip:8080/
MARZBAN_LOGIN=admin
MARZBAN_PASSWORD=your_marzban_password
USERNAME_SLUG=tg_
MAX_DEVICES=3
DATA_LIMIT=50                          # in GB

# --- YooKassa Payment ---
YOOKASSA_SHOP_ID=your_shop_id
YOOKASSA_KEY=your_secret_key
YOOKASSA_TK=your_webhook_token         # for webhook URL verification

# --- YooMoney (legacy, optional) ---
YOOMONEY_NUM=

# --- Referral System ---
DAYS_FROM_REF=5                        # bonus days per referral payment
TRY_DAYS=1                             # free trial days

# --- Partner/Affiliate Program ---
PARTNER_PERCENT=20                     # % from referred user payments
PARTNER_MIN_WITHDRAW=1000              # minimum withdrawal amount

# --- Subscription Expiry Notifications ---
HOURS_FOR_SUB_EXPIRE_NOTF=0,1,24      # hours before expiry to notify

# --- Timezone ---
TIME_ZONE=3                            # UTC offset (3 = Moscow)

# --- Render Web Service Port (auto-set by Render) ---
# PORT=10000
